# ==========================================================
# AI-Psychometrics Environment Variables Template
# ==========================================================
# INSTRUCTIONS:
# 1. Copy this file and rename it to `.env`
# 2. Fill in your actual Supabase credentials
# 3. NEVER commit your real .env file to git!
# ==========================================================

# Supabase Connection (for direct DB access in scripts)
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Vite Public Environment Variables (exposed to the frontend)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# ⚠️ IMPORTANT NOTES:
# - VITE_SUPABASE_ANON_KEY is the PUBLIC anon key (safe for frontend)
# - DATABASE_URL contains your DB password — keep it secret!
# - For GitHub Actions CI/CD, set these as GitHub Secrets:
#   → SUPABASE_URL
#   → SUPABASE_ANON_KEY
